# ==========================================
# Cravify .gitignore
# ==========================================

# ---------- Dependencies ----------
node_modules/
jspm_packages/
web_modules/
bower_components/

# ---------- Environment Variables ----------
# ⚠️ NEVER commit .env — contains DB passwords & JWT secrets
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.test
.env.production

# ---------- Build Output ----------
dist/
build/
out/
.next/
.nuxt/

# ---------- Logs ----------
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*
.pnpm-debug.log*

# ---------- Runtime / Process ----------
pids/
*.pid
*.seed
*.pid.lock

# ---------- Coverage & Testing ----------
coverage/
*.lcov
.nyc_output/

# ---------- Cache ----------
.cache/
.parcel-cache/
.eslintcache
.stylelintcache
*.tsbuildinfo
.rpt2_cache/
.rts2_cache_cjs/
.rts2_cache_es/
.rts2_cache_umd/

# ---------- IDE & Editors ----------
.vscode/
.idea/
*.swp
*.swo
*~

# ---------- OS Files ----------
.DS_Store
Thumbs.db
desktop.ini

# ---------- Compiled Binaries ----------
build/Release

# ---------- Archives ----------
*.zip
*.tar.gz
*.rar

# ---------- Misc ----------
.node_repl_history
.npm
*.tgz
.yarn-integrity
.grunt
.lock-wscript
.tern-port
.serverless/
.fusebox/
.dynamodb/
.expo/
.docusaurus/
make_zip.sh
backend/.env
backend/restaurant/.env
backend/customer/.env
backend/admin/.env
backend/delivery/.env

frontend/admin/.env
frontend/customer/.env
frontend/delivery/.env
frontend/restaurant/.env

.gitignore
